# ============================================================
# Project-level .gitignore
# ============================================================

# Dependencies
node_modules/
.npm

# Environment files (never commit secrets)
.env
.env.local
.env.production

# Build outputs
.next/
out/
dist/
build/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
*.log
