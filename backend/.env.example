# ============================================================
# The Midnight Gate — Backend Environment Configuration
# ============================================================
# Copy this file to .env and update the values as needed.
# These defaults work with the included docker-compose.yml.
# ============================================================

# Server Configuration
PORT=4000

# Redis Configuration (Docker Compose defaults)
REDIS_HOST=localhost
REDIS_PORT=6380

# PostgreSQL Configuration (Docker Compose defaults)
PG_HOST=localhost
PG_PORT=5433
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=midnight_gate
